{
  "name": "subtr-actor-three-player",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:bindings": "env PATH=$HOME/.cargo/bin:/run/current-system/sw/bin:/usr/bin:/bin npm --prefix .. run build",
    "dev": "npm run build:bindings && vite",
    "build": "npm run build:bindings && npm run check && vite build && vite build --mode library",
    "preview": "vite preview",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/three": "^0.180.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
