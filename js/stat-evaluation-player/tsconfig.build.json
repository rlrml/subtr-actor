{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@rlrml/subtr-actor": ["../pkg/rl_replay_subtr_actor.d.ts"],
      "@rlrml/player": ["../player/dist/lib.d.ts"],
      "@rlrml/player/generated/*": ["../player/dist/generated/*"],
      "three": ["./node_modules/@types/three/index.d.ts"],
      "three/examples/jsm/*": ["./node_modules/@types/three/examples/jsm/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test-helper.ts", "src/demo.ts"]
}
