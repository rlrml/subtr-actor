{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@colonelpanic8/subtr-actor": [
        "../pkg/rl_replay_subtr_actor.d.ts"
      ],
      "subtr-actor-player": [
        "../player/dist/lib.d.ts"
      ],
      "subtr-actor-player/generated/*": [
        "../player/dist/generated/*"
      ],
      "three": [
        "./node_modules/@types/three/index.d.ts"
      ],
      "three/examples/jsm/*": [
        "./node_modules/@types/three/examples/jsm/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test-helper.ts",
    "src/demo.ts"
  ]
}
