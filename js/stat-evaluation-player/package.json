{
  "name": "subtr-actor-stats-player",
  "version": "0.3.1",
  "description": "Stats-focused replay player UI for subtr-actor Rocket League replay workflows",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/lib.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build:bindings": "sh -lc 'cd .. && node --run=build'",
    "build:player": "sh -lc 'cd ../player && node --run=build'",
    "generate:stats-types": "mkdir -p src/generated && env TS_RS_EXPORT_DIR=src/generated TS_RS_IMPORT_EXTENSION=ts cargo test --manifest-path ../../Cargo.toml export_bindings --lib",
    "verify:stats-types": "node --run=generate:stats-types && git diff --exit-code -- src/generated",
    "check": "node --run=verify:stats-types && tsc --noEmit",
    "test": "tsx --tsconfig tsconfig.test.json --test src/*.test.ts",
    "build:types": "tsc --project tsconfig.build.json",
    "build": "node --run=build:bindings && node --run=build:player && node --run=check && vite build && node --run=build:types",
    "build:site": "node --run=check && vite build --mode site",
    "prepare:package": "node ./scripts/prepare-package.mjs",
    "smoke:install": "node ./scripts/smoke-install.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rlrml/subtr-actor.git",
    "directory": "js/stat-evaluation-player"
  },
  "bugs": {
    "url": "https://github.com/rlrml/subtr-actor/issues"
  },
  "homepage": "https://github.com/rlrml/subtr-actor/tree/master/js/stat-evaluation-player#readme",
  "keywords": [
    "rocket-league",
    "replay",
    "player",
    "stats",
    "threejs",
    "wasm"
  ],
  "author": "Ivan Malison <ivanmalison@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/three": "^0.180.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-wasm": "^3.6.0"
  }
}
