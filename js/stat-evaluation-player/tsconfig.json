{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "paths": {
      "@rlrml/subtr-actor": ["../pkg/rl_replay_subtr_actor.js"],
      "@rlrml/player": ["../player/src/lib.ts"],
      "@rlrml/player/generated/*": ["../player/src/generated/*"],
      "three": ["./node_modules/@types/three/index.d.ts"],
      "three/examples/jsm/*": ["./node_modules/@types/three/examples/jsm/*"]
    },
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true
  },
  "include": ["src", "src/env.d.ts"],
  "exclude": ["src/**/*.test.ts"]
}
