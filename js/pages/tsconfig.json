{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@rlrml/subtr-actor": ["../pkg/rl_replay_subtr_actor.js"],
      "@rlrml/player": ["../player/src/lib.ts"],
      "@rlrml/player/generated/*": ["../player/src/generated/*"],
      "@rlrml/viewer": ["../viewer/src/lib.ts"],
      "three": ["../stat-evaluation-player/node_modules/@types/three/index.d.ts"],
      "three/examples/jsm/*": ["../stat-evaluation-player/node_modules/@types/three/examples/jsm/*"]
    },
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true
  },
  "include": ["src"]
}
