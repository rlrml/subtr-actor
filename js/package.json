{
  "name": "@colonelpanic8/subtr-actor",
  "version": "0.7.7",
  "description": "WebAssembly bindings for subtr-actor - Rocket League replay processing and analysis",
  "main": "pkg/rl_replay_subtr_actor.js",
  "types": "pkg/rl_replay_subtr_actor.d.ts",
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg --no-pack && node ./scripts/prepare-wasm-package.mjs",
    "build:nodejs": "wasm-pack build --target nodejs --out-dir pkg-node",
    "build:bundler": "wasm-pack build --target bundler --out-dir pkg-bundler",
    "test": "wasm-pack test --headless --firefox",
    "pack": "./scripts/with-clean-npm-env.sh node --run=build && ./scripts/with-clean-npm-env.sh npm pack pkg/",
    "publish": "./scripts/with-clean-npm-env.sh node --run=build && ./scripts/with-clean-npm-env.sh npm publish pkg/",
    "prepublishOnly": "./scripts/with-clean-npm-env.sh node --run=build"
  },
  "repository": "git+https://github.com/rlrml/subtr-actor.git",
  "keywords": [
    "rocket-league",
    "replay",
    "wasm",
    "webassembly",
    "parsing"
  ],
  "author": "Ivan Malison <ivanmalison@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "wasm-pack": "^0.14.0"
  }
}
