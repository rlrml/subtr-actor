{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "src/adapter",
    "src/dev",
    "src/plugins",
    "src/lib.ts",
    "src/types.ts",
    "src/ViewerPlayer.ts"
  ]
}
