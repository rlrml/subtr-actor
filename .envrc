export NIXPKGS_ALLOW_BROKEN=1
use flake . --impure
source_env_if_exists .envrc.local

export SCROBBLE_SCRUBBER_LASTFM_USERNAME="${SCROBBLE_SCRUBBER_LASTFM_USERNAME:-$(pass show last.fm | grep user: | cut -d: -f2 | tr -d ' ')}"
export SCROBBLE_SCRUBBER_LASTFM_PASSWORD="${SCROBBLE_SCRUBBER_LASTFM_PASSWORD:-$(pass show last.fm | head -n 1)}"
export SCROBBLE_SCRUBBER_OPENAI_API_KEY="${SCROBBLE_SCRUBBER_OPENAI_API_KEY:-$(pass show open-ai-scrobble-scrubber-api-key)}"
export BALLCHASING_API_KEY="${BALLCHASING_API_KEY:-$(pass show ballchasing.com | awk -F': ' '/^api-key:/ { print $2; exit }')}"

# Export for lastfm-edit binary compatibility
export LASTFM_EDIT_USERNAME="${LASTFM_EDIT_USERNAME:-$SCROBBLE_SCRUBBER_LASTFM_USERNAME}"
export LASTFM_EDIT_PASSWORD="${LASTFM_EDIT_PASSWORD:-$SCROBBLE_SCRUBBER_LASTFM_PASSWORD}"
